{
  "framework": "vite",
  "installCommand": "npm install --prefix Frontend-main",
  "buildCommand": "npm run build --prefix Frontend-main",
  "outputDirectory": "Frontend-main/dist",
  "rewrites": [
    {
      "source": "/public/:path*",
      "destination": "https://cdn.readwith.cloud/public/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
